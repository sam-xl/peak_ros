<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <arg name="configuration" default="offline.yaml" />
    <arg name="configuration_path" default="$(find-pkg-share peak_ros)/config/$(var configuration)" />
    <arg name="ros_bag" />
    <arg name="export_pcd" default="false" />
    <arg name="logging" default="false" />
    <arg name="logging_path" default="." />
    <arg name="rosbag_name" default="peak_recording" />

    <arg name="rviz" default="true" />

    <group>
        <push_ros_namespace namespace="peak"/>

        <node_container pkg="rclcpp_components" exec="component_container" name="container" namespace="">
            <composable_node pkg="pcl_ros" plugin="pcl_ros::VoxelGrid" name="voxel_grid">
                <remap from="input" to="gated_b_scan" />
                <remap from="output" to="voxelised_gated_b_scan" />
                <param name="filter_field_name" value="z"/>
                <param name="filter_limit_min" value="0.0001"/>
                <param name="filter_limit_max" value="0.05"/>
                <param name="filter_limit_negative" value="False"/>
                <param name="leaf_size" value="0.0001"/>
                <param name="min_points_per_voxel" value="1"/>
            </composable_node>

            <composable_node pkg="peak_ros" plugin="peak_ros::ReconstructionNodelet" name="reconstruction_node">
                <remap from="input" to="voxelised_gated_b_scan" />
                <remap from="output" to="detections" />
                <param from="$(var configuration_path)" />
            </composable_node>

            <!-- PCD Exporter -->
            <composable_node pkg="pcl_ros" plugin="pcl_ros::PointCloudToPCD" name="pointcloud_to_pcd" if="$(var export_pcd)">
                <remap from="input" to="/peak/detections" />
                <param name="prefix" value="$(var logging_path)/" />
            </composable_node>

        </node_container>

        <!-- Logging -->
        <executable cmd="ros2 bag play $(var ros_bag) --topics /peak/b_scan /peak/gated_b_scan" />
        <executable cmd="ros2 bag record -o $(var logging_path)/$(var rosbag_name)_$(eval '__import__(&quot;datetime&quot;).datetime.now().strftime(&quot;%Y_%m_%d-%H_%M_%S&quot;)') --topics /tf /peak/a_scans /peak/b_scan /peak/gated_b_scan /peak/detections /robot_description" if="$(var logging)" output="screen"/>
        
    </group>

    <!-- Rviz -->
    <node pkg="rviz2" exec="rviz2" name="rviz_peak" args="-d $(find-pkg-share peak_ros)/config/bscan.rviz" if="$(var rviz)" />

</launch>